{
  "expo": {
    "name": "Aetheron Management System",
    "slug": "gym-manager-whatsapp",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "gym-manager",
    "userInterfaceStyle": "light",
    "backgroundColor": "#F3F4F6",
    "icon": "./assets/app_logo.png",
    "splash": {
      "image": "./assets/app_logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#F3F4F6"
    },
    "newArchEnabled": false,
    "jsEngine": "hermes",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/8b080331-6de2-493f-b127-966283f16220"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.mayankkush2001.gymmanagerwhatsapp",
      "adaptiveIcon": {
        "foregroundImage": "./assets/app_logo.png",
        "backgroundColor": "#F3F4F6"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 24,
            "targetSdkVersion": 34,
            "compileSdkVersion": 34
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "8b080331-6de2-493f-b127-966283f16220"
      }
    },
    "owner": "kushmayank2001"
  }
}